{
  "name": "latent-library",
  "version": "1.0.2",
  "description": "Latent Library Desktop",
  "main": "main.js",
  "author": "Alexander Nilsson",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.nilsson.latentlibrary",
    "productName": "Latent Library",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "../frontend/src/assets/icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "../frontend/src/assets/icon.png",
      "category": "Graphics"
    },
    "mac": {
      "target": "dmg",
      "icon": "../frontend/src/assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "splash.html",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/target/backend-1.0.2.jar",
        "to": "runtime/app/backend-1.0.2.jar"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}
