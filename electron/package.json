{
  "name": "ai-toolbox",
  "version": "1.0.0",
  "description": "AI Toolbox Desktop",
  "main": "main.js",
  "author": "Alexander Nilsson",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.nilsson.aitoolbox",
    "productName": "AI Toolbox",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "../frontend/src/assets/icon.png"
    },
    "files": [
      "main.js",
      "preload.js",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "runtime",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "../backend/target/backend-0.0.1-SNAPSHOT.jar",
        "to": "runtime/app/backend-0.0.1-SNAPSHOT.jar"
      }
    ]
  },
  "devDependencies": {
    "electron": "^31.0.0",
    "electron-builder": "^24.13.3"
  }
}