{
  "name": "aitoolbox-electron",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "devDependencies": {
    "electron": "^31.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.nilsson.aitoolbox",
    "productName": "AIToolbox",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "portable",
      "icon": "build/icon.ico"
    },
    "extraResources": [
      {
        "from": "../backend/target/dist/AIToolbox",
        "to": "runtime",
        "filter": [
          "**/*"
        ]
      }
    ],
    "files": [
      "**/*",
      "!dist/*"
    ]
  }
}
